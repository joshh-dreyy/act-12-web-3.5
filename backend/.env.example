# Backend Environment Variables Example
# Copy this file to .env for local development
# Set these variables in your Railway dashboard for production

# =============================================================================
# TODO 1: Environment Configuration (Easy)
# =============================================================================
# OBJECTIVE: Configure essential environment variables for deployment
#
# WHAT TO DO:
# 1. Replace placeholder values with your actual configuration
# 2. Set NODE_ENV to 'production' in Railway dashboard
# 3. Generate secure random strings for JWT_SECRET and SESSION_SECRET
# 4. Configure at least one external API key (QUEST_API_KEY)
#
# SUCCESS CRITERIA:
# ✓ All required variables have real values (not placeholders)
# ✓ Secrets are randomly generated (use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# ✓ NODE_ENV is set to 'production' in Railway (NOT in this file)
# ✓ At least one external API is configured and tested
# ✓ No sensitive values are committed to version control
#
# LEARNING GOALS:
# - Understand environment-specific configuration
# - Practice secret management best practices
# - Learn 12-factor app methodology
# - Configure production vs development environments
#
# HINT: In Railway dashboard, go to Variables tab to set these securely
# =============================================================================

# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/questtracker
REDIS_URL=redis://localhost:6379

# Security & Authentication
JWT_SECRET=your-super-secret-jwt-key-here
API_RATE_LIMIT=100
SESSION_SECRET=your-session-secret-here

# External API Keys
QUEST_API_KEY=your-external-quest-api-key
WEATHER_API_KEY=your-weather-api-key
NEWS_API_KEY=your-news-api-key

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=your-email@gmail.com

# Cloud Storage (if using)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-s3-bucket
AWS_REGION=us-east-1

# Monitoring and Logging
SENTRY_DSN=your-sentry-dsn-for-error-tracking
LOG_LEVEL=info
DATADOG_API_KEY=your-datadog-api-key

# Push Notifications
FIREBASE_SERVER_KEY=your-firebase-server-key
PUSHER_APP_ID=your-pusher-app-id
PUSHER_KEY=your-pusher-key
PUSHER_SECRET=your-pusher-secret

# Payment Processing
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Social Authentication
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Development Settings
DEBUG=true
ENABLE_CORS=true
ENABLE_LOGGING=true